10 REM GUESS THE NUMBER
20 REM CHAPTER 3
30 REM
40 CLEAR 200
50 A=16128
60 FOR I=0 TO 29
61 READ D:POKE A+I,D
62 NEXT I
70 S=RND(100)
80 POKE A+27,S
90 T=0
100 CLS
110 PRINT "GUESS A NUMBER 1-100"
120 PRINT
130 INPUT "YOUR GUESS";G
140 POKE A+28,G
150 T=T+1
160 EXEC A
170 R=PEEK(A+29)
180 IF R=0 THEN PRINT "TOO HIGH!":GOTO 120
190 IF R=1 THEN PRINT "TOO LOW!":GOTO 120
200 PRINT "YOU GOT IT IN ";T;" TRIES!"
210 END

10 REM HELLO WORLD -- HUMBLE BEGINNINGS
20 REM A 6809 Assembly Language Tutorial
30 REM
40 REM CLEAR reserves string space safely
50 CLEAR 200
60 REM
70 REM Declare all variables BEFORE VARPTR
80 REM to prevent BASIC from moving the string
90 A$=STRING$(78,0):V=0:A=0
100 REM
110 REM Get string descriptor address
120 V=VARPTR(A$)
130 REM
140 REM Descriptor bytes 1-2 = address of string data
150 A=PEEK(V+1)*256+PEEK(V+2)
160 REM
170 REM POKE machine code into the string
180 POKE A+0,189:POKE A+1,169:POKE A+2,40:POKE A+3,142
190 POKE A+4,4:POKE A+5,234:POKE A+6,49:POKE A+7,141
200 POKE A+8,0:POKE A+9,55:POKE A+10,198:POKE A+11,6
210 POKE A+12,166:POKE A+13,160:POKE A+14,129:POKE A+15,32
220 POKE A+16,39:POKE A+17,6:POKE A+18,132:POKE A+19,63
230 POKE A+20,138:POKE A+21,64:POKE A+22,32:POKE A+23,2
240 POKE A+24,134:POKE A+25,96:POKE A+26,167:POKE A+27,128
250 POKE A+28,90:POKE A+29,38:POKE A+30,237:POKE A+31,204
260 POKE A+32,4:POKE A+33,240:POKE A+34,221:POKE A+35,136
270 POKE A+36,48:POKE A+37,141:POKE A+38,0:POKE A+39,31
280 POKE A+40,141:POKE A+41,12:POKE A+42,204:POKE A+43,5
290 POKE A+44,160:POKE A+45,221:POKE A+46,136:POKE A+47,173
300 POKE A+48,159:POKE A+49,160:POKE A+50,0:POKE A+51,39
310 POKE A+52,250:POKE A+53,57:POKE A+54,166:POKE A+55,128
320 POKE A+56,39:POKE A+57,6:POKE A+58,173:POKE A+59,159
330 POKE A+60,160:POKE A+61,2:POKE A+62,32:POKE A+63,246
340 POKE A+64,57:POKE A+65,72:POKE A+66,69:POKE A+67,76
350 POKE A+68,76:POKE A+69,79:POKE A+70,32:POKE A+71,87
360 POKE A+72,79:POKE A+73,82:POKE A+74,76:POKE A+75,68
370 POKE A+76,33:POKE A+77,0
380 REM
390 REM Execute — BASIC runs our machine code
400 EXEC A

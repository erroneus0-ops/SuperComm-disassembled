{
  "group": "address",
  "description": "Load effective address — compute address into register without memory access",
  "instructions": [
    {
      "mnemonic": "LEAX",
      "full_name": "Load Effective Address into X",
      "operation": "X ← EA",
      "condition_codes": { "H": "-", "N": "-", "Z": "↕", "V": "-", "C": "-" },
      "modes": [
        { "mode": "indexed", "syntax": "LEAX expr,R", "opcode": "30", "bytes": "2+", "cycles": "4+" }
      ],
      "flow": "sequential",
      "notes": "Computes the effective address and loads it into X — no memory access. Z is set if the computed address is zero. Used for PC-relative data addressing (LEAX label,PCR), pointer arithmetic, and fast 16-bit addition (LEAX n,X adds n to X in place)."
    },
    {
      "mnemonic": "LEAY",
      "full_name": "Load Effective Address into Y",
      "operation": "Y ← EA",
      "condition_codes": { "H": "-", "N": "-", "Z": "↕", "V": "-", "C": "-" },
      "modes": [
        { "mode": "indexed", "syntax": "LEAY expr,R", "opcode": "31", "bytes": "2+", "cycles": "4+" }
      ],
      "flow": "sequential",
      "notes": "Same as LEAX but loads Y. Z reflects whether result is zero."
    },
    {
      "mnemonic": "LEAS",
      "full_name": "Load Effective Address into S",
      "operation": "S ← EA",
      "condition_codes": { "H": "-", "N": "-", "Z": "-", "V": "-", "C": "-" },
      "modes": [
        { "mode": "indexed", "syntax": "LEAS expr,R", "opcode": "32", "bytes": "2+", "cycles": "4+" }
      ],
      "flow": "sequential",
      "notes": "Does not affect Z. Used to adjust the stack pointer — LEAS -n,S reserves n bytes on the stack; LEAS n,S releases them."
    },
    {
      "mnemonic": "LEAU",
      "full_name": "Load Effective Address into U",
      "operation": "U ← EA",
      "condition_codes": { "H": "-", "N": "-", "Z": "-", "V": "-", "C": "-" },
      "modes": [
        { "mode": "indexed", "syntax": "LEAU expr,R", "opcode": "33", "bytes": "2+", "cycles": "4+" }
      ],
      "flow": "sequential",
      "notes": "Does not affect Z. Used to set up the U pointer for data access."
    }
  ]
}

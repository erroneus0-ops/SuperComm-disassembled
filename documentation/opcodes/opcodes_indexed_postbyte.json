    {
      "type": "Extended indirect",
      "syntax": "[addr]",
      "description": "16-bit absolute address in the two bytes following the postbyte. EA is the contents of that address (indirect).",
      "postbyte_values": { "": "9F" },
      "extra_bytes": 2,
      "extra_cycles": 5,
      "indirect_available": false,
      "note": "Always indirect. No register involved."
    }
  ],
  "encoding_examples": [
    {
      "syntax": "STA ,X+",
      "opcode": "A7",
      "postbyte": "80",
      "total_bytes": 2,
      "description": "Store A to address in X, then X = X + 1"
    },
    {
      "syntax": "STA ,-X",
      "opcode": "A7",
      "postbyte": "82",
      "total_bytes": 2,
      "description": "X = X - 1, then store A to new address in X"
    },
    {
      "syntax": "LDA ,X",
      "opcode": "A6",
      "postbyte": "84",
      "total_bytes": 2,
      "description": "Load A from address in X, X unchanged"
    },
    {
      "syntax": "LDA 5,Y",
      "opcode": "A6",
      "postbyte": "29",
      "total_bytes": 2,
      "description": "Load A from Y+5. 5-bit offset: bits 6-5=01 (Y), bits 4-0=00101"
    },
    {
      "syntax": "LDA $10,X",
      "opcode": "A6",
      "postbyte": "88",
      "operand": "10",
      "total_bytes": 3,
      "description": "Load A from X+$10. 8-bit offset follows postbyte."
    },
    {
      "syntax": "LDA $100,X",
      "opcode": "A6",
      "postbyte": "89",
      "operand": "$01 $00",
      "total_bytes": 4,
      "description": "Load A from X+$0100. Offset $100 exceeds 8-bit range, uses 16-bit offset mode. Two offset bytes follow postbyte."
    },
    {
      "syntax": "LDA [,X++]",
      "opcode": "A6",
      "postbyte": "91",
      "total_bytes": 2,
      "description": "Indirect: load A from address stored at X, then X = X + 2"
    }
  ]
}

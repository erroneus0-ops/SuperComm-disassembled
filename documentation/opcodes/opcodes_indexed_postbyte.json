      "indirect_postbyte_values": {
        "X": "93", "Y": "B3", "U": "D3", "S": "F3"
      }
    },
    {
      "type": "8-bit signed constant offset",
      "syntax": "n,R",
      "description": "8-bit signed offset (-128 to +127) in the byte following the postbyte.",
      "postbyte_values": {
        "X": "88", "Y": "A8", "U": "C8", "S": "E8"

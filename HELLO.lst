                      (HELLO.ASM        ):00005         ; HELLO.ASM -- Humble Beginnings
                      (HELLO.ASM        ):00006         ; Chapter 1: A 6809 Assembly Language Tutorial
                      (HELLO.ASM        ):00007         ;
                      (HELLO.ASM        ):00008         ; Demonstrates the six foundational concepts:
                      (HELLO.ASM        ):00009         ;   1. Data Movement    -- loading and storing values
                      (HELLO.ASM        ):00010         ;   2. Arithmetic       -- counters and address calculation
                      (HELLO.ASM        ):00011         ;   3. Logic            -- AND/OR to convert ASCII to VDG codes
                      (HELLO.ASM        ):00012         ;   4. Compare/Branch   -- loops and conditional flow
                      (HELLO.ASM        ):00013         ;   5. Stack/Subroutine -- BSR/RTS, saving registers
                      (HELLO.ASM        ):00014         ;   6. Indexed Addressing -- ,X+  ,Y+  auto-increment through memory
                      (HELLO.ASM        ):00015         ;
                      (HELLO.ASM        ):00016         ; Target:  TRS-80 Color Computer 1/2/3, Extended Color BASIC
                      (HELLO.ASM        ):00017         ; Format:  Position-Independent Code (PIC)
                      (HELLO.ASM        ):00018         ;          Loaded via BASIC VARPTR string method
                      (HELLO.ASM        ):00019         ;
                      (HELLO.ASM        ):00020         ; Screen result:
                      (HELLO.ASM        ):00021         ;   Row 7:  [HELLO ] WORLD!    (HELLO=inverted, WORLD!=normal)
                      (HELLO.ASM        ):00022         ;   Row 13: cursor (BASIC "OK" appears here on return)
                      (HELLO.ASM        ):00023         ;
                      (HELLO.ASM        ):00024         ; Assemble: lwasm --decb -o HELLO.BIN HELLO.ASM
                      (HELLO.ASM        ):00025         ; ================================================================
                      (HELLO.ASM        ):00026         

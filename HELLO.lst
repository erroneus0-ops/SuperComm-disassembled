                      (HELLO.ASM        ):00165         ; SUBROUTINE: PrintStr
                      (HELLO.ASM        ):00166         ; Print a null-terminated ASCII string via the CHROUT ROM routine.
                      (HELLO.ASM        ):00167         ;
                      (HELLO.ASM        ):00168         ; Entry:  X = pointer to string (null-terminated)
                      (HELLO.ASM        ):00169         ; Uses:   A (destroyed), X (advanced to end of string)
                      (HELLO.ASM        ):00170         ; Stack:  BSR pushed return address; RTS pops it
                      (HELLO.ASM        ):00171         ;
                      (HELLO.ASM        ):00172         ; Concept: Subroutine structure (entry, work, RTS)
                      (HELLO.ASM        ):00173         ;          Indexed addressing (,X+ auto-increment)
                      (HELLO.ASM        ):00174         ;          Compare and branch (null terminator check)
                      (HELLO.ASM        ):00175         ; ================================================================
0033                  (HELLO.ASM        ):00176         PrintStr
0033 A680             (HELLO.ASM        ):00177                 LDA     ,X+             ; load next char, advance X
0035 2706             (HELLO.ASM        ):00178                 BEQ     PrintDone       ; null ($00) = end of string
0037 AD9FA002         (HELLO.ASM        ):00179                 JSR     [CHROUT]        ; output character in A via ROM
003B 20F6             (HELLO.ASM        ):00180                 BRA     PrintStr        ; loop for next character
003D                  (HELLO.ASM        ):00181         PrintDone
003D 39               (HELLO.ASM        ):00182                 RTS                     ; return to caller (BSR saved address on stack)
                      (HELLO.ASM        ):00183         

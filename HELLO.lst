                      (HELLO.ASM        ):00052         ; The VDG chip does NOT use ASCII. It has two character sets:
                      (HELLO.ASM        ):00053         ;
                      (HELLO.ASM        ):00054         ;   $00-$3F  first set  芒聙聰 on the CoCo: inverted video (green on black)
                      (HELLO.ASM        ):00055         ;   $40-$7F  second set 芒聙聰 on the CoCo: normal video  (black on green)
                      (HELLO.ASM        ):00056         ;   $80-$FF  semigraphics block characters
                      (HELLO.ASM        ):00057         ;
                      (HELLO.ASM        ):00058         ; To place an uppercase ASCII letter in normal video:
                      (HELLO.ASM        ):00059         ;   ANDA #$3F   map ASCII to VDG character set (strips bits 7-6)
                      (HELLO.ASM        ):00060         ;               'H'=$48 -> $48 & $3F = $08
                      (HELLO.ASM        ):00061         ;   ORA  #$40   select normal video (black on green)
                      (HELLO.ASM        ):00062         ;               $08 | $40 = $48
                      (HELLO.ASM        ):00063         ;
                      (HELLO.ASM        ):00064         ; Without ORA #$40 the character stays in the first set and appears
                      (HELLO.ASM        ):00065         ; inverted (green on black) 芒聙聰 which is what HELLO uses deliberately.
                      (HELLO.ASM        ):00066         ;
                      (HELLO.ASM        ):00067         ; Space: $20 is inverted space (green on black, first set)
                      (HELLO.ASM        ):00068         ;        $60 is normal space  (black on green, second set)
                      (HELLO.ASM        ):00069         ; HELLO uses $20 for its trailing space to match the inverted letters.
                      (HELLO.ASM        ):00070         

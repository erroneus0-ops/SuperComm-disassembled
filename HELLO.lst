                      (HELLO.ASM        ):00046         ; Screen position formula: SCREEN + (row * COLS) + col
     04EA             (HELLO.ASM        ):00047         HELLO_POS EQU  SCREEN+(7*COLS)+10   ; row 7, col 10 = $04EA
